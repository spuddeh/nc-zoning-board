{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CP2077 Mod Map Registry",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "id",
            "name",
            "authors",
            "coordinates",
            "nexus_id",
            "description",
            "category",
            "tags"
        ],
        "properties": {
            "id": {
                "type": "string",
                "description": "UUID v4 — auto-generated, do not set manually",
                "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
            },
            "name": {
                "type": "string",
                "minLength": 3
            },
            "authors": {
                "type": "array",
                "items": {
                    "type": "string"
                },
                "minItems": 1
            },
            "credits": {
                "type": "string",
                "description": "Additional credits for teams or contributors without specific Nexus profiles"
            },
            "coordinates": {
                "type": "array",
                "items": {
                    "type": "number"
                },
                "minItems": 2,
                "maxItems": 2,
                "description": "[X, Y] — in-game coordinates from Cyber Engine Tweaks (X = east/west, Y = north/south)"
            },
            "nexus_id": {
                "type": "string",
                "pattern": "^(\\d+|WIP|Dummy)$",
                "description": "The Nexus Mods ID (number), or 'WIP' / 'Dummy' for unpublished content"
            },
            "description": {
                "type": "string",
                "maxLength": 500
            },
            "category": {
                "type": "string",
                "enum": [
                    "location-overhaul",
                    "new-location",
                    "other"
                ],
                "description": "Category of the mod: location-overhaul, new-location, or other"
            },
            "tags": {
                "type": "array",
                "items": {
                    "type": "string"
                },
                "description": "Tags for filtering and additional info (styles, lifepaths, etc.)"
            }
        }
    }
}